NODE_ENV=production
DATABASE_URL="postgresql://USER:PASSWORD@HOST-POOLER/tindog_prod?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST-DIRECT/tindog_prod?sslmode=require"
JWT_SECRET="production-secret-use-long-random-value"
PORT=3000
PASSWORD_RESET_PEPPER="production-password-reset-pepper-use-long-random-value"
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_MAX_REQUESTS_PER_HOUR=5
PASSWORD_RESET_THROTTLE_LIMIT=5
PASSWORD_RESET_VERIFY_THROTTLE_LIMIT=10
PASSWORD_RESET_THROTTLE_TTL_MS=3600000
RESEND_API_KEY="re_..."
MAIL_FROM="tinDog <noreply@tudominio.com>"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
